# =============================================================================
# IIST AdmitBot — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- AI Provider ---
# Choose: groq (recommended) or auto (alias of groq)
AI_PROVIDER=groq

# Groq (FREE — get key at console.groq.com, no credit card needed)
# Uses llama-3.3-70b-versatile model, 14,400 req/day free
GROQ_API_KEY=gsk_your_groq_api_key_here

# Legacy optional vars (kept only for backward compatibility)
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=

# --- Meta WhatsApp Business API ---
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_string
WHATSAPP_API_VERSION=v19.0

# --- Telegram Bot API ---
# Create bot in @BotFather, then paste token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Used in webhook path: /webhook/telegram/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=iist_telegram_secret

# --- Google Sheets (optional for initial deploy) ---
# Leave GOOGLE_SHEETS_ID and GOOGLE_SERVICE_ACCOUNT_JSON blank to skip lead capture
# until Sheets is ready.
# Path to Google Service Account JSON key file (or use env var GOOGLE_SERVICE_ACCOUNT_JSON)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# Or paste the full JSON content as a single-line string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SHEETS_LEADS_TAB=Leads
GOOGLE_SHEETS_INTERACTIONS_TAB=Interactions

# --- Counsellor Alerts ---
# Comma-separated WhatsApp numbers for round-robin counsellor assignment
COUNSELLOR_NUMBERS=+919575383029,+919575383029,+919575383029

# --- Reporting / Dashboard Recipients ---
HOD_WHATSAPP_NUMBER=+919575383029
PRINCIPAL_WHATSAPP_NUMBER=+919575383029
LOOKER_DASHBOARD_URL=https://lookerstudio.google.com/your-dashboard-link

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Use '*' for development, or a comma-separated list in production.
# Example: https://your-public-site.com,https://your-admin-site.com
CORS_ALLOWED_ORIGINS=*

# Service bearer token (optional) for server-to-server calls to protected APIs
API_SECRET_KEY=change_me_to_a_random_secret

# Admin dashboard session + role auth
ADMIN_SESSION_SECRET=change_this_to_a_long_random_value
ADMIN_USERS_JSON=[{"username":"admin","password":"admin123","role":"admin"},{"username":"viewer","password":"viewer123","role":"viewer"}]

# --- n8n (optional, if running alongside) ---
N8N_WEBHOOK_URL=
N8N_API_URL=https://your-n8n-host
N8N_API_KEY=your_n8n_api_key

# --- Tawk.to ---
TAWKTO_API_KEY=your_tawkto_api_key